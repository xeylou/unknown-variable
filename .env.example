# ====================================================================
#  _unknown_variable — fichier d'exemple. Copie-le en « .env » et remplis-le.
#  cp .env.example .env
# ====================================================================

# Token du bot (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=ton_token_ici

# ID de l'application (Developer Portal > General Information > Application ID)
CLIENT_ID=000000000000000000

# ID du serveur Discord (OPTIONNEL).
# Sert (1) au déploiement instantané des commandes en dev (`npm run deploy:guild`)
# et (2) de « serveur principal » pour les défauts STAFF_ROLE_ID / ADMIN_ROLE_ID /
# TICKET_* ci-dessous. Pour un bot multi-serveur : laisse vide, lance
# `npm run deploy` (global) et configure chaque serveur via /config.
GUILD_ID=

# --- Rôles staff / admin (optionnels) ---
# ⚠️ Ne servent plus que de DÉFAUT pour le serveur principal (GUILD_ID).
# Sur n'importe quel serveur, configure plutôt les rôles par serveur avec
#   /config staff role:@…    et    /config admin role:@…
# Sans rôle configuré, le bot retombe sur les permissions Discord natives
# (modération → KickMembers/BanMembers/… ; admin → permission « Administrateur »).

# Rôle modérateur par défaut du serveur principal (clic droit > Copier l'identifiant)
STAFF_ROLE_ID=

# Rôle « super-staff » / administration par défaut du serveur principal.
# Autorise les commandes sensibles : /backup, /lockdown serveur, /role temp, /setup-*, etc.
ADMIN_ROLE_ID=

# --- Identité du bot (optionnel) ---
# Nom de marque utilisé dans les logs, le User-Agent et le nom du fichier BDD.
# Le nom AFFICHÉ dans Discord vient du Developer Portal (pas d'ici).
# Défaut : _unknown_variable
BOT_NAME=
# Statuts tournants (séparés par « | »). Placeholders : {name} {count}.
# Défaut : « {name} | /help | {count} serveur(s) ».
# Ex. ancien thème : void process active|self-aware system anomaly|fatal exception occurred
BOT_STATUS=

# --- Tickets (optionnels) ---
# ⚠️ Défauts pour le serveur principal uniquement. Sur chaque serveur, préfère :
#   /config tickets categorie:#… salon-logs:#…   (catégorie + transcripts)
#   /config ticket-role categorie:… role:@…       (rôle responsable par catégorie)
# Ces valeurs ne s'appliquent JAMAIS aux autres serveurs (anti-fuite inter-serveurs).
# ID de la catégorie où ranger les tickets
TICKET_CATEGORY_ID=
# ID du salon où envoyer les transcripts de tickets fermés
LOGS_CHANNEL_ID=

# --- Notifications Twitch (optionnel) ---
# Laisse vide pour désactiver Twitch. Création : https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Musique : serveur Lavalink (optionnel) ---
# Sans LAVALINK_PASSWORD, le module musique est désactivé. Voir docs/LAVALINK.md.
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
# Mettre LAVALINK_SECURE=true si le serveur Lavalink utilise wss/https
LAVALINK_SECURE=

# --- Intégration GitHub (optionnel — désactivée si ni token ni secret) ---
# Suivi d'activité de dépôts (commits, PR/merges, CI/CD, releases…) → /git.
# Mode HYBRIDE : remplis les deux pour le temps réel + un filet de sécurité.
#
# Token : PAT fine-grained LECTURE SEULE (https://github.com/settings/tokens).
# Scopes repo conseillés : Metadata, Contents, Pull requests, Actions, Issues
# (tous en « Read-only »). Active le polling, /git statut et la résolution des
# auteurs. Sans token, seuls les webhooks alimentent les annonces.
GITHUB_TOKEN=
# Secret partagé du webhook (Settings → Webhooks du dépôt → « Secret »).
# Active le récepteur webhook (signatures vérifiées en HMAC-SHA256).
GITHUB_WEBHOOK_SECRET=
# Adresse/port/chemin d'écoute du récepteur webhook.
# URL à renseigner côté GitHub : http(s)://<hôte-public>:<port><chemin>
# Derrière un NAT/maison : expose via un tunnel (cloudflared, smee.io) ou
# laisse GITHUB_WEBHOOK_SECRET vide et utilise uniquement le polling.
GITHUB_WEBHOOK_PORT=3000
GITHUB_WEBHOOK_HOST=0.0.0.0
GITHUB_WEBHOOK_PATH=/github/webhook

# --- Sonde de santé (optionnel) ---
# Micro serveur HTTP toujours actif qui répond « ok » sur GET /health.
# Sert au HEALTHCHECK Docker et au monitoring d'uptime (UptimeRobot, etc.).
# Mettre 0 pour la désactiver. Défaut : 3001.
HEALTH_PORT=3001

# --- Miroir du chat Minecraft (optionnel — désactivé si port 0) ---
# Récepteur HTTP qui reçoit le chat en jeu (POST /mc-chat) envoyé par le pont
# côté serveur MC (scripts/mc-chat-bridge.mjs), puis le relaie dans le salon
# défini par /config minecraft-chat. L'auth se fait par un secret PAR SERVEUR
# (généré par la commande, stocké en BDD) — rien à mettre ici à part le port.
# Derrière un NAT/maison : expose le port via un tunnel (cloudflared, etc.).
MC_CHAT_PORT=0
MC_CHAT_HOST=0.0.0.0

# --- Base de données (optionnel) ---
# Chemin du fichier SQLite. Par défaut : ./data/<slug de BOT_NAME>.db
# (ex. BOT_NAME=_unknown_variable → ./data/unknown_variable.db).
# ⚠️ Si tu changes BOT_NAME alors qu'une base existe déjà, fixe DATABASE_PATH
# explicitement pour continuer à pointer dessus.
# DATABASE_PATH=./data/unknown_variable.db
