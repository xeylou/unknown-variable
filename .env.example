# ====================================================================
#  _unknown_variable — fichier d'exemple. Copie-le en « .env » et remplis-le.
#  cp .env.example .env
# ====================================================================

# Token du bot (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=ton_token_ici

# ID de l'application (Developer Portal > General Information > Application ID)
CLIENT_ID=000000000000000000

# ID du serveur Discord (clic droit sur le serveur > Copier l'identifiant)
GUILD_ID=000000000000000000

# ID du rôle staff (clic droit sur le rôle > Copier l'identifiant)
STAFF_ROLE_ID=000000000000000000

# ID du rôle « super-staff » / administration (optionnel)
# Autorise certaines commandes sensibles réservées à l'administration :
#   /backup, /lockdown serveur, /role temp, /setup-*, etc.
# Sans ADMIN_ROLE_ID, seuls les membres avec la permission Discord « Administrateur » y accèdent.
ADMIN_ROLE_ID=

# --- Tickets ---
# ID de la catégorie où ranger les tickets
TICKET_CATEGORY_ID=000000000000000000
# ID du salon où envoyer les transcripts de tickets fermés
LOGS_CHANNEL_ID=000000000000000000

# --- Notifications Twitch (optionnel) ---
# Laisse vide pour désactiver Twitch. Création : https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Musique : serveur Lavalink (optionnel) ---
# Sans LAVALINK_PASSWORD, le module musique est désactivé. Voir LAVALINK.md.
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
# Mettre LAVALINK_SECURE=true si le serveur Lavalink utilise wss/https
LAVALINK_SECURE=

# --- Intégration GitHub (optionnel — désactivée si ni token ni secret) ---
# Suivi d'activité de dépôts (commits, PR/merges, CI/CD, releases…) → /git.
# Mode HYBRIDE : remplis les deux pour le temps réel + un filet de sécurité.
#
# Token : PAT fine-grained LECTURE SEULE (https://github.com/settings/tokens).
# Scopes repo conseillés : Metadata, Contents, Pull requests, Actions, Issues
# (tous en « Read-only »). Active le polling, /git statut et la résolution des
# auteurs. Sans token, seuls les webhooks alimentent les annonces.
GITHUB_TOKEN=
# Secret partagé du webhook (Settings → Webhooks du dépôt → « Secret »).
# Active le récepteur webhook (signatures vérifiées en HMAC-SHA256).
GITHUB_WEBHOOK_SECRET=
# Adresse/port/chemin d'écoute du récepteur webhook.
# URL à renseigner côté GitHub : http(s)://<hôte-public>:<port><chemin>
# Derrière un NAT/maison : expose via un tunnel (cloudflared, smee.io) ou
# laisse GITHUB_WEBHOOK_SECRET vide et utilise uniquement le polling.
GITHUB_WEBHOOK_PORT=3000
GITHUB_WEBHOOK_HOST=0.0.0.0
GITHUB_WEBHOOK_PATH=/github/webhook

# --- Base de données (optionnel) ---
# Chemin du fichier SQLite. Par défaut : ./data/unknown_variable.db
# DATABASE_PATH=./data/unknown_variable.db
