{
  "name": "unknown_variable",
  "version": "1.0.0",
  "description": "Bot Discord multifonction — nom configurable via BOT_NAME",
  "main": "src/index.ts",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "deploy:guild": "tsx src/deploy-commands.ts --guild",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "lavalink-client": "^2.10.2",
    "prisma": "^7.8.0",
    "rcon-client": "^4.2.5",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
